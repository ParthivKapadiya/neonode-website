# NeoNode Web Solution — Environment Variables
# Copy to .env.local for local development (all optional for contact form)

# Site URL (used in metadata & sitemap)
NEXT_PUBLIC_SITE_URL=https://neonodewebsolution.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form rate limit (requests per IP per hour)
CONTACT_RATE_LIMIT=10

# ─── Optional: Email / WhatsApp alerts (not required — form works without these) ───
# CONTACT_NOTIFY_EMAIL=contact.neonode@gmail.com
# RESEND_API_KEY=
# SMTP_USER=contact.neonode@gmail.com
# SMTP_PASS=
# CALLMEBOT_API_KEY=
# WHATSAPP_NOTIFY_PHONE=918488834762
