# NeoNode Web Solution — Environment Variables
# Copy to .env.local and fill in your Gmail App Password

# Site URL (used in metadata & sitemap)
NEXT_PUBLIC_SITE_URL=https://neonodewebsolution.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Contact form rate limit (requests per IP per hour)
CONTACT_RATE_LIMIT=10

# ─── Contact Form Email (Gmail SMTP — like PHPMailer) ───────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create app password for "Mail" → copy the 16-character password
# 4. Paste it in SMTP_PASS below (no spaces)

CONTACT_NOTIFY_EMAIL=contact.neonode@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact.neonode@gmail.com
SMTP_PASS=your-gmail-app-password-here
SMTP_FROM=NeoNode Web Solution <contact.neonode@gmail.com>

# ─── Vercel: add the same variables in Project → Settings → Environment Variables
#    Enable for Production + redeploy after saving.
#    If SMTP is not set, the browser sends via FormSubmit.co directly
#    (first submission requires a one-time activation email to CONTACT_NOTIFY_EMAIL).
